@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>
<hr />

<div class="container-fluid mt-4">
    <h5 class="text-muted mb-3">Local login</h5>
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <a class="btn btn-outline-dark btn-lg d-block py-3"
               asp-action="LoginUserName">
                👤 Username
            </a>
        </div>
        <div class="col-md-3">
            <a class="btn btn-outline-dark btn-lg d-block py-3"
               asp-action="LoginEmail">
                ✉️ Email
            </a>
        </div>
    </div>

    <h5 class="text-muted mb-3">External login</h5>
    <div class="row g-3">
        <div class="col-md-3">
            <a class="btn btn-primary btn-lg d-block py-3"
               asp-action="LoginExternalProvider">
                🔐 Login via Duende IdentityServer
            </a>
        </div>
    </div>

    <div class="mt-4">
        <small class="text-muted">
            Don't have an account?
            <a asp-action="Register">Register here</a>
        </small>
    </div>
</div>