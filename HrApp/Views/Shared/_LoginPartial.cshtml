@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <span class="text-white me-2">👋 @UserManager.GetUserName(User)</span>
    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
        <button type="submit" class="btn btn-sm btn-outline-danger m-1">Logout</button>
    </form>
}
else
{
    <a class="btn btn-block link-light border-danger m-1" asp-controller="Account" asp-action="Register">Register</a>
    <a class="btn btn-block link-light border-danger m-1" asp-controller="Account" asp-action="Login">Login</a>
}